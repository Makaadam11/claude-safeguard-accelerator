{
  "name": "python",
  "description": "Safe python/pip/uv/poetry commands.",
  "allow": [
    "Bash(python --version)",
    "Bash(python3 --version)",
    "Bash(python -V)",
    "Bash(python -m pytest:*)",
    "Bash(python -m unittest:*)",
    "Bash(python -m pip list)",
    "Bash(python -m pip show:*)",
    "Bash(python -m pip freeze)",
    "Bash(pip --version)",
    "Bash(pip list)",
    "Bash(pip show:*)",
    "Bash(pip freeze)",
    "Bash(pip check)",
    "Bash(pytest)",
    "Bash(pytest:*)",
    "Bash(uv --version)",
    "Bash(uv pip list)",
    "Bash(uv run:*)",
    "Bash(uv sync)",
    "Bash(poetry --version)",
    "Bash(poetry show)",
    "Bash(poetry show:*)",
    "Bash(poetry check)",
    "Bash(poetry run pytest:*)",
    "Bash(ruff check:*)",
    "Bash(ruff format --check:*)",
    "Bash(mypy:*)",
    "Bash(black --check:*)"
  ]
}
