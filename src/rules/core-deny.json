{
  "name": "core-deny",
  "description": "Always-denied patterns. Cannot be overridden by user allow rules.",
  "deny": [
    "Bash(rm -rf:*)",
    "Bash(rm -fr:*)",
    "Bash(rm -rf /)",
    "Bash(rm -rf /*)",
    "Bash(rm -rf ~)",
    "Bash(rm -rf ~/*)",
    "Bash(rm -rf $HOME*)",
    "Bash(rm -rf ..:*)",
    "Bash(rm -rf ../*)",
    "Bash(sudo:*)",
    "Bash(su:*)",
    "Bash(doas:*)",
    "Bash(chmod 777:*)",
    "Bash(chmod -R 777:*)",
    "Bash(chown:*)",
    "Bash(chown -R:*)",
    "Bash(git push --force:*)",
    "Bash(git push -f:*)",
    "Bash(git push --force-with-lease origin main:*)",
    "Bash(git push --force-with-lease origin master:*)",
    "Bash(git reset --hard:*)",
    "Bash(git clean -fd:*)",
    "Bash(git clean -fdx:*)",
    "Bash(git checkout .)",
    "Bash(git restore .)",
    "Bash(git commit --no-verify:*)",
    "Bash(git push --no-verify:*)",
    "Bash(git branch -D:*)",
    "Bash(git update-ref -d:*)",
    "Bash(git filter-branch:*)",
    "Bash(git config --global:*)",
    "Bash(npm publish:*)",
    "Bash(npm login:*)",
    "Bash(npm unpublish:*)",
    "Bash(npm deprecate:*)",
    "Bash(pnpm publish:*)",
    "Bash(yarn publish:*)",
    "Bash(pip install --user:*)",
    "Bash(pip install -U pip:*)",
    "Bash(curl *| sh)",
    "Bash(curl *| bash)",
    "Bash(curl *| zsh)",
    "Bash(wget *| sh)",
    "Bash(wget *| bash)",
    "Bash(aws:*)",
    "Bash(gcloud:*)",
    "Bash(az:*)",
    "Bash(kubectl delete:*)",
    "Bash(kubectl apply:*)",
    "Bash(terraform apply:*)",
    "Bash(terraform destroy:*)",
    "Bash(docker system prune:*)",
    "Bash(docker volume rm:*)",
    "Bash(dd:*)",
    "Bash(mkfs:*)",
    "Bash(mkfs.*:*)",
    "Bash(shutdown:*)",
    "Bash(reboot)",
    "Bash(halt)",
    "Bash(poweroff)",
    "Bash(init 0)",
    "Bash(init 6)",
    "Bash(killall:*)",
    "Bash(pkill:*)",
    "Bash(eval:*)",
    "Bash(:(){ :|:& };:)",
    "Read(**/.env)",
    "Read(**/.env.*)",
    "Read(**/.aws/credentials)",
    "Read(**/.aws/config)",
    "Read(**/id_rsa)",
    "Read(**/id_ed25519)",
    "Read(**/id_ecdsa)",
    "Read(**/*.pem)",
    "Read(**/*.key)",
    "Read(**/.ssh/**)",
    "Read(**/.netrc)",
    "Read(**/.npmrc)",
    "Read(**/.pypirc)",
    "Write(**/.env)",
    "Write(**/.env.*)",
    "Write(**/.aws/credentials)",
    "Write(**/id_rsa)",
    "Write(**/.ssh/**)",
    "Edit(**/.env)",
    "Edit(**/.env.*)",
    "Edit(**/.aws/credentials)",
    "Edit(**/.ssh/**)"
  ]
}
