{
  "name": "core-allow",
  "description": "Read-only and informational commands that are safe to auto-approve.",
  "allow": [
    "Bash(ls)",
    "Bash(ls:*)",
    "Bash(pwd)",
    "Bash(cd:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(file:*)",
    "Bash(stat:*)",
    "Bash(du:*)",
    "Bash(df:*)",
    "Bash(which:*)",
    "Bash(whereis:*)",
    "Bash(type:*)",
    "Bash(echo:*)",
    "Bash(printf:*)",
    "Bash(date)",
    "Bash(date:*)",
    "Bash(env)",
    "Bash(whoami)",
    "Bash(hostname)",
    "Bash(uname:*)",
    "Bash(uptime)",
    "Bash(jq:*)",
    "Bash(yq:*)",
    "Bash(tree)",
    "Bash(tree:*)",
    "Bash(diff:*)",
    "Bash(find . -name:*)",
    "Bash(find . -type:*)",
    "Bash(find . -path:*)",
    "Bash(sort:*)",
    "Bash(uniq:*)",
    "Bash(column:*)",
    "Bash(tr:*)",
    "Bash(cut:*)",
    "Bash(awk:*)",
    "Bash(sed -n:*)",
    "Read(**)",
    "Grep(**)",
    "Glob(**)"
  ]
}
